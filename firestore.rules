rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: officials
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - gender: string (optional, enum: ["M", "F", "Other"])
    //   - position: string (required)
    //   - group: string (required)
    //   - order: number (optional)
    //
    // Collection: missions
    // Document ID: auto-generated
    // Fields:
    //   - officialId: string (required)
    //   - month: number (required, 1-12)
    //   - year: number (required)
    //   - days: list (required, items: number 1-31)
    //
    // Collection: groups
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //
    // Collection: committees
    // Document ID: auto-generated
    // Fields:
    //   - leaderName: string (required) - ឈ្មោះថ្នាក់ដឹកនាំ
    //   - leaderPosition: string (required) - តួនាទី
    //   - documentNumber: string (optional) - លេខលិខិត
    //   - objective: string (required) - កម្មវត្ថុ
    //   - ministry: string (optional) - ក្រសួង
    //   - fileUrl: string (optional) - ឯកសារ
    //   - notes: string (optional) - ផ្សេងៗ
     // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isVerified() {
      return isAuthenticated() && 
             (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'password');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
        (request.auth.token.email == "lasediii.info@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isEditor() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role in ['admin', 'editor']) ||
        (request.auth.token.email == "lasediii.info@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['admin', 'editor', 'viewer'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 256)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1024));
    }

    function isValidOfficial(data) {
      return data.keys().hasAll(['name', 'position', 'group']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.position is string && data.position.size() > 0 && data.position.size() < 100 &&
             data.group is string && data.group.size() > 0 && data.group.size() < 100 &&
             (!('gender' in data) || (data.gender in ['M', 'F', 'Other'])) &&
             (!('order' in data) || (data.order is number));
    }

    function isValidMission(data) {
      return data.keys().hasAll(['officialId', 'month', 'year', 'days']) &&
             data.officialId is string &&
             data.month is number && data.month >= 1 && data.month <= 12 &&
             data.year is number &&
             data.days is list && data.days.size() <= 31 &&
             (!('notes' in data) || (data.notes is map && data.notes.size() <= 31));
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() < 500));
    }

    function isValidCommittee(data) {
      return data.keys().hasAll(['leaderName', 'leaderPosition', 'objective']) &&
             data.leaderName is string && data.leaderName.size() > 0 && data.leaderName.size() < 200 &&
             data.leaderPosition is string && data.leaderPosition.size() > 0 && data.leaderPosition.size() < 200 &&
             data.objective is string && data.objective.size() > 0 && data.objective.size() < 1000 &&
             (!('documentNumber' in data) || (data.documentNumber is string && data.documentNumber.size() < 200)) &&
             (!('ministry' in data) || (data.ministry is string && data.ministry.size() < 500)) &&
             (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() < 1000)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 2000)) &&
             (!('order' in data) || (data.order is number)) &&
             (!('createdAt' in data) || (data.createdAt is string));
    }

    function isValidTask(data) {
      return data.keys().hasAll(['activity', 'status']) &&
             data.activity is string && data.activity.size() > 0 && data.activity.size() < 1000 &&
             data.status in ['⚠️ មិនទាន់ចាប់ផ្តើម', '✅ បញ្ចប់រួចរាល់', '🏃 កំពុងដំណើរការ', '❌ ផ្អាក'] &&
             (!('startDate' in data) || (data.startDate is string)) &&
             (!('deadline' in data) || (data.deadline is string)) &&
             (!('responsiblePerson' in data) || (data.responsiblePerson is string && data.responsiblePerson.size() < 500)) &&
             (!('documentType' in data) || (data.documentType in ['meeting', 'feedback'])) &&
             (!('typeColor' in data) || (data.typeColor is string && data.typeColor.size() < 50)) &&
             (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() < 1000)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 2000)) &&
             (!('order' in data) || (data.order is number)) &&
             (!('createdAt' in data) || (data.createdAt is string));
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'action', 'collection', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.action in ['CREATE', 'UPDATE', 'DELETE'] &&
             data.collection is string &&
             data.collection.size() < 100 &&
             data.timestamp is string &&
             (!('userEmail' in data) || (data.userEmail is string)) &&
             (!('documentId' in data) || (data.documentId is string)) &&
             (!('details' in data) || (data.details is string && data.details.size() < 5000));
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidLog(incoming());
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isAdmin() && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    match /officials/{officialId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor() && isValidOfficial(incoming());
      allow delete: if isEditor();
    }

    match /missions/{missionId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor() && isValidMission(incoming());
      allow delete: if isEditor();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidGroup(incoming());
      allow delete: if isAdmin();
    }

    match /committees/{committeeId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor() && isValidCommittee(incoming());
      allow delete: if isEditor();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor() && isValidTask(incoming());
      allow delete: if isEditor();
    }

    match /files/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isEditor();
      allow update, delete: if isEditor();
    }

    match /file_chunks/{chunkId} {
      allow read: if isAuthenticated();
      allow create: if isEditor() && 
                       incoming().data is string &&
                       incoming().data.size() < 1048576;
      allow update, delete: if isEditor();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
